<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="0" prefWidth="420.0" style="-fx-background-color: #0F1923; -fx-font-family: 'Segoe UI';"
     xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
     fx:controller="com.someone.valvoicegui.SettingsController">

    <!-- Custom Title Bar (Draggable) -->
    <HBox fx:id="settingsTitleBar" alignment="CENTER_LEFT" spacing="10" prefHeight="35.0"
          style="-fx-background-color: #0F1923; -fx-border-color: #FF4655; -fx-border-width: 0 0 2 0;">
        <padding><Insets left="15" /></padding>
        <Label text="⚙" style="-fx-font-size: 16;" />
        <Label text="ENGINE SETTINGS" style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-font-family: 'Bebas Neue'; -fx-font-size: 16;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnSettingsClose" text="✕" onAction="#handleSettingsClose"
                prefWidth="35.0" prefHeight="35.0"
                style="-fx-background-color: transparent; -fx-text-fill: #9AA0A6; -fx-font-size: 12; -fx-cursor: hand; -fx-background-radius: 0; -fx-border-radius: 0;" />
    </HBox>

    <!-- Content -->
    <VBox spacing="20" style="-fx-padding: 25;">

        <Separator style="-fx-background-color: rgba(255,255,255,0.1);" />

        <!-- PTT Key -->
        <VBox spacing="5">
            <Label text="Push-to-Talk Key" style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold;" />
            <TextField fx:id="pttKeyField" maxWidth="80.0" promptText="V"
                       style="-fx-background-color: #1F2E3C; -fx-text-fill: #ECE8E1; -fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 1; -fx-background-radius: 0; -fx-border-radius: 0; -fx-font-size: 16; -fx-alignment: CENTER;" />
            <Label text="Single letter or number (matches Valorant PTT key)"
                   style="-fx-text-fill: #9AA0A6; -fx-font-size: 11;" />
        </VBox>

        <!-- XTTS Enable -->
        <CheckBox fx:id="xttsEnabledCheckBox" text="Enable XTTS Agent Voices"
                  style="-fx-text-fill: #ECE8E1;" />

        <!-- SAPI Fallback -->
        <CheckBox fx:id="sapiFallbackCheckBox" text="Enable SAPI Fallback (when XTTS unavailable)"
                  style="-fx-text-fill: #ECE8E1;" />

        <!-- Volume -->
        <VBox spacing="5">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Playback Volume" style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold;" />
                <Label fx:id="volumeValueLabel" text="100%" style="-fx-text-fill: #9AA0A6;" />
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="🔈" style="-fx-font-size: 14;" />
                <Slider fx:id="volumeSlider" min="0.0" max="1.0" value="1.0" blockIncrement="0.05"
                        showTickMarks="true" showTickLabels="false" majorTickUnit="0.25"
                        HBox.hgrow="ALWAYS" style="-fx-control-inner-background: #1F2E3C;" />
                <Label text="🔊" style="-fx-font-size: 14;" />
            </HBox>
        </VBox>

        <!-- Language -->
        <VBox spacing="5">
            <Label text="TTS Language" style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold;" />
            <ChoiceBox fx:id="languageChoice" maxWidth="200.0"
                       style="-fx-background-color: #1F2E3C; -fx-mark-color: #ECE8E1;" />
            <Label text="Language used for XTTS voice generation"
                   style="-fx-text-fill: #9AA0A6; -fx-font-size: 11;" />
        </VBox>

        <Separator style="-fx-background-color: rgba(255,255,255,0.1);" />

        <!-- Action Buttons -->
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button text="🔊 TEST VOICE" onAction="#handleTestVoice"
                    prefWidth="140.0" prefHeight="36.0"
                    style="-fx-background-color: #1F2E3C; -fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-background-radius: 0; -fx-border-radius: 0; -fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 1; -fx-cursor: hand;" />
            <Button fx:id="saveButton" text="SAVE &amp; CLOSE" onAction="#handleSave"
                    prefWidth="140.0" prefHeight="36.0"
                    style="-fx-background-color: #FF4655; -fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-background-radius: 0; -fx-border-radius: 0; -fx-cursor: hand;" />
        </HBox>
    </VBox>
</VBox>
