<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<!--
    Phase 8 Step 3: First-Run Setup Wizard
    Catppuccin Mocha dark theme matching existing ValVoice UI.
    4 pages: Welcome → Environment Check → Audio Setup → Finish
-->
<VBox spacing="0" prefWidth="520.0" minHeight="480.0"
     style="-fx-background-color: #0F1923; -fx-font-family: 'Segoe UI';"
     xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
     fx:controller="com.someone.valvoicegui.SetupWizardController">

    <!-- ===== Custom Title Bar (Draggable) ===== -->
    <HBox fx:id="wizardTitleBar" alignment="CENTER_LEFT" spacing="10" prefHeight="35.0"
          style="-fx-background-color: #0F1923; -fx-border-color: #FF4655; -fx-border-width: 0 0 2 0;">
        <padding><Insets left="15" /></padding>
        <Label text="🎤" style="-fx-font-size: 18;" />
        <Label text="VALVOICE SETUP" style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-font-family: 'Bebas Neue'; -fx-font-size: 16;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnWizardMinimize" text="—" onAction="#handleWizardMinimize"
                prefWidth="35.0" prefHeight="35.0"
                style="-fx-background-color: transparent; -fx-text-fill: #9AA0A6; -fx-font-size: 12; -fx-cursor: hand; -fx-background-radius: 0; -fx-border-radius: 0;" />
        <Button fx:id="btnWizardClose" text="✕" onAction="#handleWizardClose"
                prefWidth="35.0" prefHeight="35.0"
                style="-fx-background-color: transparent; -fx-text-fill: #9AA0A6; -fx-font-size: 12; -fx-cursor: hand; -fx-background-radius: 0; -fx-border-radius: 0;" />
    </HBox>

    <!-- ===== Sub-header ===== -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: #1F2E3C; -fx-padding: 15 25 15 25;">
        <VBox spacing="2">
            <Label text="First-Time Setup" style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-font-family: 'Bebas Neue'; -fx-font-size: 20;" />
            <Label text="Configure your environment before launch"
                   style="-fx-text-fill: #9AA0A6; -fx-font-size: 12; -fx-font-family: 'Segoe UI';" />
        </VBox>
    </HBox>

    <Separator style="-fx-background-color: rgba(255,255,255,0.1);" />

    <!-- ===== Scrollable Page Container (content scrolls, buttons stay pinned) ===== -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;">
        <StackPane fx:id="wizardPages"
                   style="-fx-padding: 25;">

        <!-- ==================== PAGE 1: Welcome ==================== -->
        <VBox fx:id="page1Welcome" spacing="18" alignment="TOP_LEFT">
            <Label text="WELCOME TO VALVOICE" style="-fx-text-fill: #FF4655; -fx-font-weight: bold; -fx-font-family: 'Bebas Neue'; -fx-font-size: 22;" />

            <Label text="ValVoice reads your Valorant in-game chat messages aloud using AI-powered text-to-speech, then plays them through voice chat so your teammates can hear callouts instantly."
                   wrapText="true" style="-fx-text-fill: #ECE8E1; -fx-font-size: 13;" />

            <Separator style="-fx-background-color: rgba(255,255,255,0.1);" />

            <Label text="This wizard will help you:" style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-font-size: 14;" />

            <VBox spacing="10" style="-fx-padding: 0 0 0 10;">
                <Label text="✓  Verify required system dependencies" style="-fx-text-fill: #FF4655; -fx-font-size: 13;" />
                <Label text="✓  Check audio device configuration" style="-fx-text-fill: #FF4655; -fx-font-size: 13;" />
                <Label text="✓  Guide you through Valorant setup" style="-fx-text-fill: #FF4655; -fx-font-size: 13;" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Label text="Click Next to begin."
                   style="-fx-text-fill: #9AA0A6; -fx-font-size: 12;" />
        </VBox>

        <!-- ==================== PAGE 2: Environment Check ==================== -->
        <VBox fx:id="page2Environment" spacing="16" alignment="TOP_LEFT"
              visible="false" managed="false">
            <Label text="ENVIRONMENT CHECK" style="-fx-text-fill: #FF4655; -fx-font-weight: bold; -fx-font-family: 'Bebas Neue'; -fx-font-size: 22;" />

            <Label text="Checking required system dependencies..."
                   wrapText="true" style="-fx-text-fill: #ECE8E1; -fx-font-size: 13;" />

            <Separator style="-fx-background-color: rgba(255,255,255,0.1);" />

            <!-- Dependency Status Grid -->
            <VBox spacing="14" style="-fx-padding: 10 0 0 0;">

                <!-- VB-Cable -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="VB-Audio Virtual Cable"
                               style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-font-size: 14;" />
                        <Label text="Required for audio routing to Valorant"
                               style="-fx-text-fill: #9AA0A6; -fx-font-size: 11;" />
                    </VBox>
                    <Label fx:id="statusVbCable" text="⏳ Checking..."
                           style="-fx-text-fill: #FF4655; -fx-font-size: 14;" />
                </HBox>

                <!-- SoundVolumeView -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="SoundVolumeView.exe"
                               style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-font-size: 14;" />
                        <Label text="Required for per-process audio device routing"
                               style="-fx-text-fill: #9AA0A6; -fx-font-size: 11;" />
                    </VBox>
                    <Label fx:id="statusSoundVolumeView" text="⏳ Checking..."
                           style="-fx-text-fill: #FF4655; -fx-font-size: 14;" />
                </HBox>

                <!-- PowerShell -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Windows PowerShell"
                               style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-font-size: 14;" />
                        <Label text="Required for SAPI fallback voice engine"
                               style="-fx-text-fill: #9AA0A6; -fx-font-size: 11;" />
                    </VBox>
                    <Label fx:id="statusPowerShell" text="⏳ Checking..."
                           style="-fx-text-fill: #FF4655; -fx-font-size: 14;" />
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <!-- Warning / Success label -->
            <Label fx:id="envWarningLabel" text=""
                   wrapText="true" visible="false" managed="false"
                   style="-fx-text-fill: #FF4655; -fx-font-size: 13;" />
        </VBox>

        <!-- ==================== PAGE 3: Audio Setup ==================== -->
        <VBox fx:id="page3Audio" spacing="16" alignment="TOP_LEFT"
              visible="false" managed="false">
            <Label text="VALORANT AUDIO SETUP" style="-fx-text-fill: #FF4655; -fx-font-weight: bold; -fx-font-family: 'Bebas Neue'; -fx-font-size: 22;" />

            <Label text="Configure Valorant to receive ValVoice audio through voice chat."
                   wrapText="true" style="-fx-text-fill: #ECE8E1; -fx-font-size: 13;" />

            <Separator style="-fx-background-color: rgba(255,255,255,0.1);" />

            <VBox spacing="16" style="-fx-padding: 8 0 0 0;">
                <HBox spacing="12" alignment="TOP_LEFT">
                    <Label text="1." style="-fx-text-fill: #FF4655; -fx-font-weight: bold; -fx-font-size: 16;" minWidth="25" />
                    <Label text="Open Valorant Settings"
                           wrapText="true" style="-fx-text-fill: #ECE8E1; -fx-font-size: 14;" />
                </HBox>

                <HBox spacing="12" alignment="TOP_LEFT">
                    <Label text="2." style="-fx-text-fill: #FF4655; -fx-font-weight: bold; -fx-font-size: 16;" minWidth="25" />
                    <Label text="Navigate to Audio → Voice Chat"
                           wrapText="true" style="-fx-text-fill: #ECE8E1; -fx-font-size: 14;" />
                </HBox>

                <HBox spacing="12" alignment="TOP_LEFT">
                    <Label text="3." style="-fx-text-fill: #FF4655; -fx-font-weight: bold; -fx-font-size: 16;" minWidth="25" />
                    <VBox spacing="4">
                        <Label text="Set Input Device (Microphone) to:"
                               wrapText="true" style="-fx-text-fill: #ECE8E1; -fx-font-size: 14;" />
                        <Label text="CABLE Output (VB-Audio Virtual Cable)"
                               style="-fx-text-fill: #FF4655; -fx-font-weight: bold; -fx-font-size: 15;
                                      -fx-background-color: #1F2E3C; -fx-padding: 6 12 6 12;" />
                    </VBox>
                </HBox>

                <HBox spacing="12" alignment="TOP_LEFT">
                    <Label text="4." style="-fx-text-fill: #FF4655; -fx-font-weight: bold; -fx-font-size: 16;" minWidth="25" />
                    <Label text="Ensure Push-to-Talk key matches your ValVoice config (default: V)"
                           wrapText="true" style="-fx-text-fill: #ECE8E1; -fx-font-size: 14;" />
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Label text="You can change these settings later in the ValVoice Settings panel."
                   style="-fx-text-fill: #9AA0A6; -fx-font-size: 11;" />
        </VBox>

        <!-- ==================== PAGE 4: Finish ==================== -->
        <VBox fx:id="page4Finish" spacing="18" alignment="CENTER"
              visible="false" managed="false">
            <Label text="🎉" style="-fx-font-size: 48;" />

            <Label text="YOU'RE ALL SET!" style="-fx-text-fill: #FF4655; -fx-font-weight: bold; -fx-font-family: 'Bebas Neue'; -fx-font-size: 26;" />

            <Label text="ValVoice is ready to use."
                   style="-fx-text-fill: #ECE8E1; -fx-font-size: 14;" />

            <Separator style="-fx-background-color: rgba(255,255,255,0.1);" prefWidth="300" />

            <VBox spacing="8" alignment="CENTER">
                <Label text="Remember:" style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-font-size: 14;" />
                <Label text="• Start ValVoice BEFORE launching Valorant"
                       style="-fx-text-fill: #9AA0A6; -fx-font-size: 13;" />
                <Label text="• Set Valorant microphone to CABLE Output"
                       style="-fx-text-fill: #9AA0A6; -fx-font-size: 13;" />
                <Label text="• Use Settings to customize PTT key and volume"
                       style="-fx-text-fill: #9AA0A6; -fx-font-size: 13;" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Label text="Click Finish to launch ValVoice."
                   style="-fx-text-fill: #9AA0A6; -fx-font-size: 12;" />
        </VBox>

    </StackPane>
    </ScrollPane>

    <Separator style="-fx-background-color: rgba(255,255,255,0.1);" />

    <!-- ===== Navigation Buttons (Riot Tactical Style) ===== -->
    <HBox alignment="CENTER_RIGHT" spacing="12"
          style="-fx-background-color: #1F2E3C; -fx-padding: 15 25 15 25;">
        <Button fx:id="backButton" text="← BACK" onAction="#handleBack"
                visible="false" managed="false"
                prefWidth="100.0" prefHeight="34.0"
                style="-fx-background-color: #1F2E3C; -fx-text-fill: #ECE8E1;
                       -fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 1;
                       -fx-background-radius: 0; -fx-border-radius: 0; -fx-cursor: hand; -fx-font-weight: bold;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="nextButton" text="NEXT →" onAction="#handleNext"
                prefWidth="100.0" prefHeight="34.0"
                style="-fx-background-color: #FF4655; -fx-text-fill: #ECE8E1;
                       -fx-font-weight: bold; -fx-background-radius: 0; -fx-border-radius: 0; -fx-cursor: hand;" />
        <Button fx:id="finishButton" text="✓ FINISH" onAction="#handleFinish"
                visible="false" managed="false"
                prefWidth="120.0" prefHeight="34.0"
                style="-fx-background-color: #FF4655; -fx-text-fill: #ECE8E1;
                       -fx-font-weight: bold; -fx-background-radius: 0; -fx-border-radius: 0; -fx-cursor: hand;" />
    </HBox>

</VBox>
