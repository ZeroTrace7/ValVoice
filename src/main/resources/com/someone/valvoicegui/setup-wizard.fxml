<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<!--
    Phase 8 Step 3: First-Run Setup Wizard
    Valorant tactical dark theme — custom title bar, UNDECORATED stage.
    4 pages: Welcome → Environment Check → Audio Setup → Finish
-->
<VBox spacing="0" prefWidth="520.0" prefHeight="480.0"
     style="-fx-background-color: #0F1923;"
     xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
     fx:controller="com.someone.valvoicegui.SetupWizardController">

    <!-- ===== Custom Title Bar ===== -->
    <HBox fx:id="titleBar" prefHeight="35.0" alignment="CENTER_LEFT" spacing="8"
          style="-fx-background-color: #0F1923; -fx-padding: 0 0 0 15;"
          onMousePressed="#handleTitleBarMousePressed"
          onMouseDragged="#handleTitleBarMouseDragged">
        <Label text="ValVoice Setup" style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-font-size: 13;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="minimizeButton" text="_" onAction="#handleMinimize"
                style="-fx-background-color: transparent; -fx-text-fill: #ECE8E1; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 14 4 14;" />
        <Button fx:id="closeButton" text="✕" onAction="#handleClose"
                style="-fx-background-color: transparent; -fx-text-fill: #ECE8E1; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 14 0 14;" />
    </HBox>

    <!-- ===== Header ===== -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: #1F2E3C; -fx-padding: 20 25 20 25;">
        <Label text="🎤" style="-fx-font-size: 28;" />
        <VBox spacing="2">
            <Label text="ValVoice Setup" style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold;" styleClass="header-label">
                <font><Font size="22.0" /></font>
            </Label>
            <Label text="First-time configuration wizard"
                   style="-fx-text-fill: #9aa0a6; -fx-font-size: 12;" />
        </VBox>
    </HBox>

    <Separator style="-fx-background-color: #FF4655;" />

    <!-- ===== Page Container ===== -->
    <StackPane fx:id="wizardPages" VBox.vgrow="ALWAYS"
               style="-fx-padding: 25; -fx-background-color: #0F1923;">

        <!-- ==================== PAGE 1: Welcome ==================== -->
        <VBox fx:id="page1Welcome" spacing="18" alignment="TOP_LEFT">
            <Label text="Welcome to ValVoice!" style="-fx-text-fill: #FF4655; -fx-font-weight: bold;" styleClass="header-label">
                <font><Font size="18.0" /></font>
            </Label>

            <Label text="ValVoice reads your Valorant in-game chat messages aloud using AI-powered text-to-speech, then plays them through voice chat so your teammates can hear callouts instantly."
                   wrapText="true" style="-fx-text-fill: #ECE8E1; -fx-font-size: 13;" />

            <Separator style="-fx-background-color: #1F2E3C;" />

            <Label text="This wizard will help you:" style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-font-size: 14;" />

            <VBox spacing="10" style="-fx-padding: 0 0 0 10;">
                <Label text="✓  Verify required system dependencies" style="-fx-text-fill: #ECE8E1; -fx-font-size: 13;" />
                <Label text="✓  Check audio device configuration" style="-fx-text-fill: #ECE8E1; -fx-font-size: 13;" />
                <Label text="✓  Guide you through Valorant setup" style="-fx-text-fill: #ECE8E1; -fx-font-size: 13;" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Label text="Click Next to begin."
                   style="-fx-text-fill: #9aa0a6; -fx-font-size: 12;" />
        </VBox>

        <!-- ==================== PAGE 2: Environment Check ==================== -->
        <VBox fx:id="page2Environment" spacing="16" alignment="TOP_LEFT"
              visible="false" managed="false">
            <Label text="Environment Check" style="-fx-text-fill: #FF4655; -fx-font-weight: bold;" styleClass="header-label">
                <font><Font size="18.0" /></font>
            </Label>

            <Label text="Checking required system dependencies..."
                   wrapText="true" style="-fx-text-fill: #ECE8E1; -fx-font-size: 13;" />

            <Separator style="-fx-background-color: #1F2E3C;" />

            <!-- Dependency Status Grid -->
            <VBox spacing="14" style="-fx-padding: 10 0 0 0;">

                <!-- VB-Cable -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="VB-Audio Virtual Cable"
                               style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-font-size: 14;" />
                        <Label text="Required for audio routing to Valorant"
                               style="-fx-text-fill: #9aa0a6; -fx-font-size: 11;" />
                    </VBox>
                    <Label fx:id="statusVbCable" text="⏳ Checking..."
                           style="-fx-text-fill: #ECE8E1; -fx-font-size: 14;" />
                </HBox>

                <!-- SoundVolumeView -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="SoundVolumeView.exe"
                               style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-font-size: 14;" />
                        <Label text="Required for per-process audio device routing"
                               style="-fx-text-fill: #9aa0a6; -fx-font-size: 11;" />
                    </VBox>
                    <Label fx:id="statusSoundVolumeView" text="⏳ Checking..."
                           style="-fx-text-fill: #ECE8E1; -fx-font-size: 14;" />
                </HBox>

                <!-- PowerShell -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Windows PowerShell"
                               style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-font-size: 14;" />
                        <Label text="Required for SAPI fallback voice engine"
                               style="-fx-text-fill: #9aa0a6; -fx-font-size: 11;" />
                    </VBox>
                    <Label fx:id="statusPowerShell" text="⏳ Checking..."
                           style="-fx-text-fill: #ECE8E1; -fx-font-size: 14;" />
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <!-- Warning / Success label -->
            <Label fx:id="envWarningLabel" text=""
                   wrapText="true" visible="false" managed="false"
                   style="-fx-text-fill: #ECE8E1; -fx-font-size: 13;" />
        </VBox>

        <!-- ==================== PAGE 3: Audio Setup ==================== -->
        <VBox fx:id="page3Audio" spacing="16" alignment="TOP_LEFT"
              visible="false" managed="false">
            <Label text="Valorant Audio Setup" style="-fx-text-fill: #FF4655; -fx-font-weight: bold;" styleClass="header-label">
                <font><Font size="18.0" /></font>
            </Label>

            <Label text="Configure Valorant to receive ValVoice audio through voice chat."
                   wrapText="true" style="-fx-text-fill: #ECE8E1; -fx-font-size: 13;" />

            <Separator style="-fx-background-color: #1F2E3C;" />

            <VBox spacing="16" style="-fx-padding: 8 0 0 0;">
                <HBox spacing="12" alignment="TOP_LEFT">
                    <Label text="1." style="-fx-text-fill: #FF4655; -fx-font-weight: bold; -fx-font-size: 16;" minWidth="25" />
                    <Label text="Open Valorant Settings"
                           wrapText="true" style="-fx-text-fill: #ECE8E1; -fx-font-size: 14;" />
                </HBox>

                <HBox spacing="12" alignment="TOP_LEFT">
                    <Label text="2." style="-fx-text-fill: #FF4655; -fx-font-weight: bold; -fx-font-size: 16;" minWidth="25" />
                    <Label text="Navigate to Audio → Voice Chat"
                           wrapText="true" style="-fx-text-fill: #ECE8E1; -fx-font-size: 14;" />
                </HBox>

                <HBox spacing="12" alignment="TOP_LEFT">
                    <Label text="3." style="-fx-text-fill: #FF4655; -fx-font-weight: bold; -fx-font-size: 16;" minWidth="25" />
                    <VBox spacing="4">
                        <Label text="Set Input Device (Microphone) to:"
                               wrapText="true" style="-fx-text-fill: #ECE8E1; -fx-font-size: 14;" />
                        <Label text="CABLE Output (VB-Audio Virtual Cable)"
                               style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-font-size: 15;
                                      -fx-background-color: #1F2E3C; -fx-padding: 6 12 6 12;" />
                    </VBox>
                </HBox>

                <HBox spacing="12" alignment="TOP_LEFT">
                    <Label text="4." style="-fx-text-fill: #FF4655; -fx-font-weight: bold; -fx-font-size: 16;" minWidth="25" />
                    <Label text="Ensure Push-to-Talk key matches your ValVoice config (default: V)"
                           wrapText="true" style="-fx-text-fill: #ECE8E1; -fx-font-size: 14;" />
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Label text="You can change these settings later in the ValVoice Settings panel."
                   style="-fx-text-fill: #9aa0a6; -fx-font-size: 11;" />
        </VBox>

        <!-- ==================== PAGE 4: Finish ==================== -->
        <VBox fx:id="page4Finish" spacing="18" alignment="CENTER"
              visible="false" managed="false">
            <Label text="🎉" style="-fx-font-size: 48;" />

            <Label text="You're All Set!" style="-fx-text-fill: #FF4655; -fx-font-weight: bold;" styleClass="header-label">
                <font><Font size="22.0" /></font>
            </Label>

            <Label text="ValVoice is ready to use."
                   style="-fx-text-fill: #ECE8E1; -fx-font-size: 14;" />

            <Separator style="-fx-background-color: #1F2E3C;" prefWidth="300" />

            <VBox spacing="8" alignment="CENTER">
                <Label text="Remember:" style="-fx-text-fill: #ECE8E1; -fx-font-weight: bold; -fx-font-size: 14;" />
                <Label text="• Start ValVoice BEFORE launching Valorant"
                       style="-fx-text-fill: #ECE8E1; -fx-font-size: 13;" />
                <Label text="• Set Valorant microphone to CABLE Output"
                       style="-fx-text-fill: #ECE8E1; -fx-font-size: 13;" />
                <Label text="• Use Settings to customize PTT key and volume"
                       style="-fx-text-fill: #ECE8E1; -fx-font-size: 13;" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Label text="Click Finish to launch ValVoice."
                   style="-fx-text-fill: #9aa0a6; -fx-font-size: 12;" />
        </VBox>

    </StackPane>

    <Separator style="-fx-background-color: #1F2E3C;" />

    <!-- ===== Navigation Buttons ===== -->
    <HBox alignment="CENTER_RIGHT" spacing="12"
          style="-fx-background-color: #1F2E3C; -fx-padding: 15 25 15 25;">
        <Button fx:id="backButton" text="← Back" onAction="#handleBack"
                visible="false" managed="false"
                prefWidth="100.0" prefHeight="34.0"
                styleClass="button"
                style="-fx-background-color: #1F2E3C; -fx-text-fill: #ECE8E1; -fx-cursor: hand;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="nextButton" text="Next →" onAction="#handleNext"
                prefWidth="100.0" prefHeight="34.0"
                styleClass="primary-button"
                style="-fx-font-weight: bold; -fx-cursor: hand;" />
        <Button fx:id="finishButton" text="✓ Finish" onAction="#handleFinish"
                visible="false" managed="false"
                prefWidth="120.0" prefHeight="34.0"
                styleClass="primary-button"
                style="-fx-font-weight: bold; -fx-cursor: hand;" />
    </HBox>

</VBox>

